{
  "version": 2,
  "regions": ["iad1"],
  "packageManager": "pip@latest",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "buildCommand": "pip install -r backend/requirements.txt",
  "outputDirectory": "backend",
  "functions": {
    "backend/main.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ]
}

